---
import CoockiesAgreement from 'src/components/CoockiesAgreement.astro';
import Footer from '../components/Footer.astro';
import PrimeHeader from '../components/PrimeHeader.astro';
import SecondHeader from '../components/SecondHeader.astro';
import BurgerPanel from 'src/components/BurgerPanel.astro';
import ContactFormDrawer from 'src/components/ContactFormDrawer.astro';
import ThanksDrawer from 'src/components/ThanksDrawer.astro';
import ExceptionDrawer from 'src/components/ExceptionDrawer.astro';

interface Props {
	title: string;
	description: string;
	empty?: boolean;
}

const { title, description, empty = false } = Astro.props;

const mode = import.meta.env.MODE as ("development" | "production");
---

<!doctype html>
<html lang="en" data-mode={mode}>
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/x-icon" href="favicon-32x32.png" />
		<meta name="generator" content={Astro.generator} />
		<meta name="app-mode" content={mode} />
		<style is:inline>
			/* @import url(https://fonts.googleapis.com/css?family=Inter+Tight:regular,500,600,700,500italic&display=swap); */
			/* 	100	Thin (Hairline)
					200	Extra Light (Ultra Light)
					300	Light
					400	Normal
					500	Medium
					600	Semi Bold (Demi Bold)
					700	Bold
					800	Extra Bold (Ultra Bold)
					900	Black (Heavy) */
			@import url(https://fonts.googleapis.com/css?family=Inter:300,regular,500,600,700,800);
			@import url(https://fonts.googleapis.com/css?family=Onest:regular,500,600,700);
		</style>
		{mode === "production" && <link rel="stylesheet" href="./assets/main.css" />}
		<script is:inline src="./libs/fslightbox.js" type="module"></script>
		<script is:inline src="./assets/main.js" type="module"></script>
		<title>{title}</title>
	</head>
	<body class="tg-regular">
		<style>
			.splash {
				display: flex;
				flex-direction: column;
				align-items: center;
				justify-content: center;
				position: fixed;
				z-index: 1000000;
				left: 0;
				top: 0;
				width: 100%;
				height: 100%;
				background-color: #1E5E46;
			}
			.splash._hidden {
				display: none;
			}
			.splash__lightning {
				width: 5.625rem;
				margin-bottom: 5.75rem;
				@media (max-width: 575px) {
					width: 4rem;
					margin-bottom: 3rem;
				}
			}
			.splash__lightning-progress {
				height: var(--progress, 0%);
			}
			.splash__logo {
				width: 14.75rem;
				margin-bottom: 1rem;
			}
			.splash__progress {
				font-weight: 500;
				font-size: 18px;
				line-height: 120%;
				letter-spacing: -0.03em;
				color: #F5F5F2;
				&::after {
					content: "%";
				}
			}
			
		</style>
		<div class="splash">
			<svg class="splash__lightning" viewBox="0 0 90 198" fill="none" xmlns="http://www.w3.org/2000/svg">
				<mask id="lightning-mask" style="mask-type:alpha" maskUnits="userSpaceOnUse" x="0" y="0" width="90" height="198">
