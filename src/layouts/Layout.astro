			</svg>
			<div class="splash__progress">0</div>
		</div>
		<script>
			var pageLoad = document.readyState === 'complete';
			var splash = document.querySelector(".splash")  as HTMLElement;
			var progressElem = splash?.querySelector(".splash__progress") as HTMLElement;
			var barCompleted = false;
			var progress = 0;
			var step = 2;
			var intervalId = setInterval(function() {
				progress += step;
				progressElem.textContent = progress.toString();
				splash?.style.setProperty("--progress", 100 - Number(progress) + "%");
				if (progress >= 100) {
					clearInterval(intervalId);
					setBarCompleted(true);
				}
			}, 5);
			window.addEventListener("load", () => setPageLoad(true));
			function setBarCompleted(next: boolean) {
				barCompleted = next;
				combineComplete();
			}
			function setPageLoad(next: boolean) {
				pageLoad = next;
				combineComplete();
			}
			function combineComplete() {
				if (pageLoad && barCompleted) complete();
			}
			function complete() {
				document.documentElement.classList.add("_ready");
				splash.classList.add("_hidden");
			}
		</script>
		{empty ? null : <Fragment>
											<PrimeHeader/>
											<SecondHeader/>
										</Fragment>}
		<main>
			<slot />
		</main>
		{empty ? null : <Footer></Footer>}
		<div class="drawers" data-lenis-prevent>
			<BurgerPanel />
			<CoockiesAgreement />
			<ContactFormDrawer />
			<ThanksDrawer />
			<ExceptionDrawer />
		</div>
		<div class="page-drawers">
			<slot name="drawers" />
		</div>
		<div class="go-up-layer">
			<div class="container go-up-layer__container">
				<button type="button" class="btn btn_icon go-up-layer__btn" data-component=":go-up-btn:">
					<span class="icon-arrow-up btn__icon"></span>
				</button>
			</div>
		</div>
	</body>
</html>